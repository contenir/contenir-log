{
    "name": "contenir/contenir-log",
    "description": "Pluggable PSR-3 logger for Laminas MVC and Mezzio, with filesystem and database storage backends.",
    "type": "library",
    "license": "MIT",
    "keywords": ["log", "logger", "psr-3", "laminas", "mezzio", "contenir"],
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "psr/container": "^1.0 || ^2.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "laminas/laminas-db": "^2.17"
    },
    "require-dev": {
        "laminas/laminas-coding-standard": "^3.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": { "Contenir\\Log\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Contenir\\Log\\Tests\\": "tests/" }
    },
    "extra": {
        "laminas": {
            "module": "Contenir\\Log",
            "config-provider": "Contenir\\Log\\ConfigProvider"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs",
        "cs-fix": "phpcbf"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
